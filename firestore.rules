// Firestore Security Rules — Syllabix
//
// ⚠️ CE FICHIER REFLÈTE LES RÈGLES RÉELLEMENT DÉPLOYÉES EN PRODUCTION.
// Il a été reconstruit le 2026-07-14 à partir du ruleset live, puis complété
// pour la fondation « organisations ». Sauvegarde de l'état antérieur :
// firestore.rules.PROD-BACKUP
//
// Principe : les données sensibles (certificats, progression, badges,
// rattachement à une organisation, sessions d'examen) sont écrites par
// l'Admin SDK via les API routes — l'Admin SDK ignore ces règles.
// Le client ne peut donc PAS forger un certificat, un badge ni un rattachement.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Fonctions utilitaires ──────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // Champs autorisés dans un profil utilisateur.
    // NB : 'badges', 'orgId', 'orgType', 'orgJoinedAt' sont écrits par le
    // serveur (Admin SDK). Ils DOIVENT figurer dans cette liste, sinon le
    // client ne peut plus mettre à jour son propre profil dès qu'il possède
    // un badge ou un rattachement — leur écriture reste interdite au client
    // par la garde `affectedKeys()` de la règle `update` ci-dessous.
    function validUserProfile() {
      return request.resource.data.keys().hasOnly([
        'email', 'firstName', 'lastName', 'displayName',
        'phoneNumber', 'phoneVerified', 'emailVerified',
        'dateOfBirth', 'parentalConsentGiven', 'parentalConsentAt',
        'role', 'createdAt', 'updatedAt', 'authProvider',
        'profileComplete', 'phoneVerifiedAt', 'emailVerifiedAt',
        'badges', 'orgId', 'orgType', 'orgJoinedAt', 'orgUnit'
      ]);
    }

    // Valide qu'un certificat public vient bien du bon user
    function validPublicCert(userId) {
      return request.resource.data.userId == userId
          && request.resource.data.keys().hasAll(['userId', 'score', 'certTitle', 'createdAt'])
          && request.resource.data.score is number
          && request.resource.data.score >= 0
          && request.resource.data.score <= 100;
    }

    // Valide les données de progression (empêche les scores falsifiés)
    function validProgress() {
      return request.resource.data.keys().hasOnly([
            'moduleId', 'score', 'answers', 'completedAt'
          ])
          && request.resource.data.score is number
          && request.resource.data.score >= 0
          && request.resource.data.score <= 100;
    }

    // Valide les tentatives d'examen (empêche la manipulation du cooldown)
    function validExamAttempt() {
      return request.resource.data.keys().hasOnly(['lastAttemptAt'])
          && request.resource.data.lastAttemptAt == request.time;
    }

    // ─── Collection : users ─────────────────────────────────────────
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && validUserProfile();
      // Le client ne peut modifier ni son rôle, ni ses badges, ni son
      // rattachement à une organisation (réservés à l'Admin SDK).
      allow update: if isOwner(userId)
                    && validUserProfile()
                    && (!request.resource.data.diff(resource.data).affectedKeys()
                         .hasAny(['role', 'email', 'createdAt', 'authProvider',
                                  'badges', 'orgId', 'orgType', 'orgJoinedAt',
                                  'orgUnit']));
      allow delete: if false;

      match /progress/{moduleId} {
        allow read:   if isOwner(userId);
        allow create: if isOwner(userId) && validProgress();
        allow update: if isOwner(userId) && validProgress();
        allow delete: if false;
      }

      match /certificates/{certId} {
        allow read:   if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if false;
        allow delete: if false;
      }

      match /examAttempts/{examKey} {
        allow read:  if isOwner(userId);
        allow write: if isOwner(userId) && validExamAttempt();
        allow delete: if false;
      }

      match /sessions/{sessionId} {
        allow read:   if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if false;
        allow delete: if false;
      }
    }

    // ─── Collection : certificates (publique, partage/LinkedIn) ────
    match /certificates/{certId} {
      allow read: if true;
      allow create: if isAuth()
                    && validPublicCert(request.auth.uid);
      allow update: if false;
      allow delete: if false;
    }

    // ─── Collection : publicBadges (badges partagés publiquement) ──
    // Représentation publique d'un badge, créée à la demande via
    // /api/badge/share (Admin SDK). Lecture publique pour le partage social ;
    // aucune écriture client.
    match /publicBadges/{badgeId} {
      allow read:  if true;
      allow write: if false;
    }

    // ─── Collections : vouchers & voucherBatches (codes de certification) ──
    // Codes qui débloquent une certification. Générés, validés et consommés
    // EXCLUSIVEMENT par l'Admin SDK (/api/voucher/*, /api/admin/voucher/*).
    // Aucun accès client (anti-énumération / anti-forge).
    match /vouchers/{code}       { allow read, write: if false; }
    match /voucherBatches/{id}   { allow read, write: if false; }
    match /counters/{docId}      { allow read, write: if false; }

    // ─── Collection : organizations (écoles & entreprises) ──────────
    // Aucun accès client : le rattachement et l'administration passent
    // EXCLUSIVEMENT par les API routes en Admin SDK (/api/org/*, /api/admin/*).
    match /organizations/{orgId} {
      allow read, write: if false;
    }

    // ─── Collection : modules (banque de questions) ─────────────────
    match /modules/{moduleId} {
      allow read: if isAuth();
      allow write: if false;

      match /questions/{questionId} {
        allow read:  if isAuth();
        allow write: if false;
      }
    }

    // ─── Collection : articles (blog) ───────────────────────────────
    match /articles/{articleId} {
      allow read:  if true;
      allow write: if false; // écriture via /api/admin/blog/* (Admin SDK)
    }

    // ─── Collection : testimonials (accueil) ───────────────────────
    match /testimonials/{testimonialId} {
      allow read:  if true;
      allow write: if false; // écriture via /api/admin/testimonials/* (Admin SDK)
    }

    // ─── Collection : rateLimits ─────────────────────────────────────
    // Compteurs de limitation de débit (endpoints publics). Admin SDK only.
    match /rateLimits/{key} {
      allow read, write: if false;
    }

    // ─── Collection : partnershipRequests ───────────────────────────
    // Demandes de partenariat déposées depuis /partenariats.
    // Aucun accès client : l'écriture passe par /api/partnership/request
    // (Admin SDK), la lecture par /api/admin/partnership/list.
    match /partnershipRequests/{requestId} {
      allow read, write: if false;
    }

    // ─── Collection : newsletter ─────────────────────────────────────
    match /newsletter/{docId} {
      allow create: if request.resource.data.keys().hasOnly(['email', 'subscribedAt'])
                    && request.resource.data.email is string
                    && request.resource.data.email.size() > 5;
      allow read:   if false; // lecture via /api/admin/newsletter/list (Admin SDK)
      allow update: if false;
      allow delete: if false;
    }
  }
}
